# Auto-normalize line endings (Windows build -> Mac deploy)
* text=auto

# Force LF for shell scripts (Mac/Linux execution)
*.sh text eol=lf

# Force CRLF for Windows-specific scripts
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary files
*.db binary
*.sqlite binary
*.png binary
*.jpg binary
*.ico binary
